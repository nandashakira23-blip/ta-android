<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLeaveMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_surface"
        app:tabIndicatorColor="@color/primary_brown"
        app:tabSelectedTextColor="@color/text_primary"
        app:tabTextColor="@color/brown_400" />

    <LinearLayout
        android:id="@+id/layoutFormTab"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/dark_surface"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Pengajuan Absensi"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Ajukan cuti, izin, atau sakit. Isi pengganti jika tugas perlu dialihkan."
                            android:textColor="@color/brown_400"
                            android:textSize="12sp" />

                        <RadioGroup
                            android:id="@+id/rgLeaveType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rbCuti"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cuti"
                                android:textColor="@color/text_primary" />

                            <RadioButton
                                android:id="@+id/rbIzin"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:checked="true"
                                android:text="Izin"
                                android:textColor="@color/text_primary" />

                            <RadioButton
                                android:id="@+id/rbSakit"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Sakit"
                                android:textColor="@color/text_primary" />
                        </RadioGroup>

                        <EditText
                            android:id="@+id/etTanggalMulai"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@color/dark_surface_variant"
                            android:clickable="true"
                            android:focusable="false"
                            android:hint="Tanggal mulai"
                            android:padding="12dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_muted" />

                        <EditText
                            android:id="@+id/etTanggalSelesai"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@color/dark_surface_variant"
                            android:clickable="true"
                            android:focusable="false"
                            android:hint="Tanggal selesai"
                            android:padding="12dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_muted" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/etJamMulai"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@color/dark_surface_variant"
                                android:clickable="true"
                                android:focusable="false"
                                android:hint="Jam mulai"
                                android:padding="12dp"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_muted" />

                            <View
                                android:layout_width="10dp"
                                android:layout_height="1dp" />

                            <EditText
                                android:id="@+id/etJamSelesai"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@color/dark_surface_variant"
                                android:clickable="true"
                                android:focusable="false"
                                android:hint="Jam selesai"
                                android:padding="12dp"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Isi jam untuk izin sebagian (per jam). Kosongkan untuk izin seharian."
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <AutoCompleteTextView
                                android:id="@+id/actvPengganti"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@color/dark_surface_variant"
                                android:completionThreshold="0"
                                android:dropDownHeight="240dp"
                                android:dropDownVerticalOffset="4dp"
                                android:hint="Cari karyawan pengganti (opsional)"
                                android:inputType="text"
                                android:padding="12dp"
                                android:singleLine="true"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_muted" />

                            <TextView
                                android:id="@+id/btnClearPengganti"
                                android:layout_width="44dp"
                                android:layout_height="match_parent"
                                android:layout_marginStart="8dp"
                                android:background="@color/leave_status_cancelled"
                                android:gravity="center"
                                android:text="X"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:visibility="gone" />
                        </LinearLayout>

                        <EditText
                            android:id="@+id/etAlasan"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/dark_surface_variant"
                            android:gravity="top|start"
                            android:hint="Alasan pengajuan"
                            android:inputType="textMultiLine"
                            android:padding="12dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_muted" />

                        <Button
                            android:id="@+id/btnPickAttachment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="@color/leave_status_cancelled"
                            android:text="Pilih Lampiran (sakit wajib)"
                            android:textAllCaps="false"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvAttachmentName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Belum ada lampiran"
                            android:textColor="@color/brown_400"
                            android:textSize="12sp" />

                        <Button
                            android:id="@+id/btnSubmitLeave"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="@color/primary_brown"
                            android:text="Kirim Pengajuan"
                            android:textAllCaps="false"
                            android:textColor="@color/text_primary" />

                        <ProgressBar
                            android:id="@+id/progressLeave"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="14dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutHistoryTab"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Riwayat Absensi"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEmptyLeave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Memuat data..."
            android:textColor="@color/brown_400"
            android:textSize="14sp" />

        <ListView
            android:id="@+id/listLeaveHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:divider="@android:color/transparent"
            android:dividerHeight="10dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutReplacementTab"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Approval Pengganti"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEmptyReplacement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Memuat data..."
            android:textColor="@color/brown_400"
            android:textSize="14sp" />

        <ListView
            android:id="@+id/listReplacementRequests"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="10dp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
